---
const { name, role, quote } = Astro.props;
---
<figure class="rounded-2xl border border-white/10 bg-[#006633] p-6 text-white shadow-sm hover-glow">
  <blockquote class="text-slate-100">"{quote}"</blockquote>
  <figcaption class="mt-4 text-sm text-slate-200">
    <div class="font-semibold text-white">{name}</div>
    <div class="text-xs text-slate-200/80">{role}</div>
  </figcaption>
</figure>
