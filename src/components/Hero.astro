---
const { eyebrow, title, description, ctaText, ctaHref, image } = Astro.props;
---
<section class="relative min-h-screen overflow-hidden text-white flex items-center">
  {image ? (
    <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${image}')`} aria-hidden="true"></div>
  ) : null}
  <div class="absolute inset-0 bg-slate-950/25" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-slate-950/30 via-slate-950/10 to-transparent" aria-hidden="true"></div>

  <div class="container relative z-10 py-28">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm uppercase tracking-[0.24em] text-white/80">{eyebrow}</p>
      <h1 class="text-5xl font-semibold tracking-tight sm:text-6xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-200">{description}</p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a href={ctaHref} class="btn-brand">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
          Boek nu een intake
        </a>
        <a href="/cases" class="btn-brand">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Bekijk cases
        </a>
      </div>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      <div class="rounded-[2rem] bg-white/10 p-8 shadow-2xl shadow-slate-950/10 backdrop-blur-md border border-white/10 hover-glow">
        <p class="text-sm uppercase tracking-[0.24em] text-emerald-200">Direct zichtbaar</p>
        <h2 class="mt-4 text-2xl font-semibold text-white">Een website die meteen vertrouwen wekt</h2>
        <p class="mt-3 text-slate-200">Met een krachtige eerste indruk, duidelijke contactinformatie en lokale call-to-actions.</p>
      </div>
      <div class="rounded-[2rem] bg-white/10 p-8 shadow-2xl shadow-slate-950/10 backdrop-blur-md border border-white/10 hover-glow">
        <p class="text-sm uppercase tracking-[0.24em] text-white/80">Persoonlijk proces</p>
        <h2 class="mt-4 text-2xl font-semibold text-white">Samen werken aan jouw online uitstraling</h2>
        <p class="mt-3 text-slate-200">We houden het simpel, persoonlijk en gericht op jouw vakgebied en regio.</p>
      </div>
    </div>
  </div>
</section>
