---
// Herbruikbaar contactformulier onderaan elke pagina
// Foto links, formulier rechts — donkere achtergrond
---
<section class="relative overflow-hidden bg-slate-900">
  <div class="grid lg:grid-cols-2" style="min-height:560px">

    <!-- Foto links -->
    <div class="relative hidden lg:block">
      <img
        src="/images/about-story.jpeg"
        alt="Neem contact op met VB-DigitalMarketing"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <!-- overlay met groene tint -->
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/60 via-[#006633]/30 to-transparent"></div>

      <!-- Badge over de foto -->
      <div class="absolute bottom-10 left-10 rounded-2xl border border-white/20 bg-white/10 p-6 backdrop-blur-sm">
        <p class="text-3xl font-black text-white">4.9 ★</p>
        <p class="mt-1 text-sm text-white/80">Gemiddelde Google-beoordeling</p>
        <p class="mt-3 text-sm font-semibold text-white">&#10003; Reactie binnen 24 uur</p>
        <p class="text-sm font-semibold text-white">&#10003; Gratis vrijblijvend gesprek</p>
      </div>
    </div>

    <!-- Formulier rechts -->
    <div class="flex flex-col justify-center px-8 py-16 lg:px-14">
      <span class="inline-flex w-fit rounded-full border border-[#7C3AED]/40 bg-[#7C3AED]/15 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.3em] text-[#a78bfa]">Neem contact op</span>
      <h2 class="mt-4 text-4xl font-bold leading-tight text-white">
        Klaar om online<br />te groeien?
      </h2>
      <p class="mt-3 text-white/60">Vul je gegevens in — wij nemen binnen 24 uur contact op voor een gratis en vrijblijvend gesprek.</p>

      <form
        name="contact"
        method="POST"
        action="/contact"
        class="mt-8 space-y-4"
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-white/50">Naam</label>
            <input
              type="text"
              name="naam"
              required
              placeholder="Jouw naam"
              class="w-full rounded-xl border border-white/10 bg-white/8 px-4 py-3 text-sm text-white placeholder-white/30 outline-none transition focus:border-[#7C3AED]/60 focus:bg-white/12 focus:ring-2 focus:ring-[#7C3AED]/20"
              style="background:rgba(255,255,255,0.07)"
            />
          </div>
          <div>
            <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-white/50">Telefoonnummer</label>
            <input
              type="tel"
              name="telefoon"
              placeholder="06 — — — — — —"
              class="w-full rounded-xl border border-white/10 bg-white/8 px-4 py-3 text-sm text-white placeholder-white/30 outline-none transition focus:border-[#7C3AED]/60 focus:bg-white/12 focus:ring-2 focus:ring-[#7C3AED]/20"
              style="background:rgba(255,255,255,0.07)"
            />
          </div>
        </div>

        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-white/50">E-mailadres</label>
          <input
            type="email"
            name="email"
            required
            placeholder="jouw@email.nl"
            class="w-full rounded-xl border border-white/10 bg-white/8 px-4 py-3 text-sm text-white placeholder-white/30 outline-none transition focus:border-[#7C3AED]/60 focus:bg-white/12 focus:ring-2 focus:ring-[#7C3AED]/20"
            style="background:rgba(255,255,255,0.07)"
          />
        </div>

        <div>
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-white/50">Jouw vraag of bericht</label>
          <textarea
            name="bericht"
            rows="4"
            placeholder="Waar kan ik je mee helpen?"
            class="w-full rounded-xl border border-white/10 bg-white/8 px-4 py-3 text-sm text-white placeholder-white/30 outline-none transition focus:border-[#7C3AED]/60 focus:ring-2 focus:ring-[#7C3AED]/20 resize-none"
            style="background:rgba(255,255,255,0.07)"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-xl bg-[#7C3AED] px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-[#7C3AED]/30 transition hover:bg-[#6D28D9] hover:shadow-[#7C3AED]/40 hover:-translate-y-0.5"
        >
          Verstuur bericht &rarr;
        </button>

        <p class="text-center text-xs text-white/35">Geen spam. Geen verplichtingen. Alleen een eerlijk gesprek.</p>
      </form>
    </div>

  </div>
</section>
