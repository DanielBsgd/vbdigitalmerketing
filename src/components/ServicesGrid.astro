---
const services = Astro.props.services ?? [
  { key: 'website', title: 'Website laten maken', desc: 'Heldere presentatie, contact en portfolio.', slug: 'website-laten-maken', photo: '/images/service-website-photo.svg' },
  { key: 'seo', title: 'Lokale SEO', desc: 'Landingspagina's en zoekwoordoptimalisatie.', slug: 'lokale-seo', photo: '/images/service-seo-photo.svg' },
  { key: 'content', title: 'Content & Blog', desc: 'Richtinggevende content voor langdurige groei.', slug: 'content-en-blog', photo: '/images/service-content-photo.svg' },
  { key: 'blog', title: 'Blog & Content', desc: 'Regelmatig content die lokaal scoort.', slug: 'blog-en-content', photo: '/images/service-blog-photo.svg' },
];
---
<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {services.map((s) => (
    <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm flex flex-col hover-glow">
      <div class="flex items-center gap-4">
        <img src={s.photo} alt="" class="w-20 h-14 rounded-md object-cover" />
        <div>
          <h3 class="font-semibold text-slate-900">{s.title}</h3>
          <p class="mt-1 text-slate-600">{s.desc}</p>
        </div>
      </div>
      <div class="mt-6">
        <a href={`/diensten/${s.slug}`} class="btn-brand btn-icon"><img src={s.photo} alt="" class="inline-block mr-2 w-6 h-6 rounded-md"/> Meer info</a>
      </div>
    </div>
  ))}
</div>
