---
const { title, excerpt, image, link } = Astro.props;
---
<a href={link} target="_blank" rel="noreferrer"
   class="group relative flex flex-col overflow-hidden rounded-2xl bg-white border border-slate-100 shadow-md transition-all duration-500 ease-out hover:-translate-y-2 hover:border-[#006633]/20 hover:shadow-xl">

  <div class="relative overflow-hidden">
    <div class="aspect-video overflow-hidden">
      <img src={image} alt={title}
           class="h-full w-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-105" />
    </div>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-semibold text-slate-900">{title}</h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{excerpt}</p>
    <span class="mt-5 inline-flex items-center justify-center rounded-lg border border-[#006633] bg-[#006633] px-4 py-2 text-xs font-semibold text-white transition group-hover:bg-[#004d26]">
      Bezoek site
    </span>
  </div>
</a>
