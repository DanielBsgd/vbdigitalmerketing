---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Website laten maken | VB-DigitalMarketing';
const description = 'Professionele websites voor vakmensen. Snelle oplevering en lokaal gericht.';
---

<BaseLayout {title} {description}>
  <section class="container py-16 bg-[#004d26] rounded-lg">
    <div class="grid gap-8 lg:grid-cols-2 items-center">
      <div>
        <h1 class="text-3xl font-semibold text-slate-900">Website laten maken</h1>
        <p class="mt-4 text-slate-700">Wij bouwen heldere, conversiegerichte websites voor schilders, timmermannen en loodgieters. Gericht op snelle vindbaarheid en leads.</p>
        <a href="/contact" class="btn-brand mt-6">Plan intake</a>
      </div>
      <div>
        <img src="/images/service-website-photo.svg" alt="Website foto" class="rounded-lg shadow-md" />
      </div>
    </div>
  </section>
</BaseLayout>
