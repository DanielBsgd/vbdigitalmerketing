---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Maandelijkse werkzaamheden | VB-DigitalMarketing';
const description = 'Wat doen wij elke maand voor jou? Ontdek onze maandelijkse werkzaamheden voor hosting, SEO, content en onderhoud van jouw website.';
---
<BaseLayout {title} {description}>

  <!-- Hero — full screen, foto rechts -->
  <section class="relative min-h-screen overflow-hidden bg-[#006633] flex items-center">
    <!-- Foto rechts (absoluut gepositioneerd) -->
    <div class="absolute right-0 top-0 hidden h-full w-1/2 lg:block">
      <img src="/images/about-story.jpeg" alt="Maandelijkse werkzaamheden" class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#006633] via-[#006633]/60 to-transparent"></div>
    </div>

    <!-- Tekst links -->
    <div class="container relative z-10 py-24 lg:py-0">
      <div class="max-w-xl">
        <span class="inline-flex rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.3em] text-white">Maandelijkse werkzaamheden</span>
        <h1 class="mt-6 text-5xl font-bold tracking-tight text-white lg:text-6xl">
          Wij zorgen elke maand voor jouw website
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-8 text-white/80">
          Hosting, SEO, blogs en updates — wij regelen het allemaal. Jij focust op je vak, wij zorgen dat de aanvragen blijven binnenkomen.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href="/contact" class="btn-brand">Plan een gesprek</a>
          <a href="/cases" class="btn-ghost">Bekijk voorbeelden</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews -->
  <section class="bg-white py-16">
    <div class="container">
      <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <span class="section-label">Klantbeoordelingen</span>
          <h2 class="mt-3 text-3xl font-semibold text-slate-900">Wat onze klanten zeggen</h2>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 self-start">
          <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="text-sm font-semibold text-slate-700">Google Reviews</span>
          <span class="text-yellow-400">★★★★★</span>
          <span class="text-sm font-bold text-slate-900">4.9</span>
          <span class="text-sm text-slate-500">(18 reviews)</span>
        </div>
      </div>

      <!--
        TIP: Vervang deze statische reviews door een echte widget, bijv.:
        Elfsight (gratis): https://elfsight.com/google-reviews-widget/
        Plak hier je widget-code zodra je die hebt aangemaakt.
      -->
      <div class="grid gap-6 md:grid-cols-3">

        <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#006633] text-sm font-bold text-white">P</div>
            <div class="min-w-0">
              <p class="font-semibold text-slate-900">Peter Smits</p>
              <p class="text-yellow-400 text-sm">★★★★★</p>
            </div>
            <svg viewBox="0 0 24 24" class="ml-auto h-5 w-5 shrink-0">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
          <p class="mt-4 flex-1 text-slate-600">"Al 6 maanden nemen zij het onderhoud van mijn website over. Ik merk dat ik hoger sta in Google en dat er meer klanten bellen."</p>
          <p class="mt-4 text-xs text-slate-400">2 maanden geleden</p>
        </div>

        <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#7C3AED] text-sm font-bold text-white">L</div>
            <div class="min-w-0">
              <p class="font-semibold text-slate-900">Lisa van den Berg</p>
              <p class="text-yellow-400 text-sm">★★★★★</p>
            </div>
            <svg viewBox="0 0 24 24" class="ml-auto h-5 w-5 shrink-0">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
          <p class="mt-4 flex-1 text-slate-600">"De maandelijkse blogs zorgen ervoor dat ik gevonden word op zoekwoorden die ik zelf nooit had bedacht. Erg blij mee!"</p>
          <p class="mt-4 text-xs text-slate-400">1 maand geleden</p>
        </div>

        <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-700 text-sm font-bold text-white">J</div>
            <div class="min-w-0">
              <p class="font-semibold text-slate-900">Jan Willems</p>
              <p class="text-yellow-400 text-sm">★★★★★</p>
            </div>
            <svg viewBox="0 0 24 24" class="ml-auto h-5 w-5 shrink-0">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
          <p class="mt-4 flex-1 text-slate-600">"Geen omkijken meer naar mijn website. Ze regelen alles en ik ontvang elke maand een helder rapport. Aanrader!"</p>
          <p class="mt-4 text-xs text-slate-400">4 maanden geleden</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Plannen -->
  <section id="plannen" class="bg-slate-50 py-20">
    <div class="container">
      <div class="max-w-2xl mb-12">
        <span class="section-label">Onze plannen</span>
        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Kies jouw maandelijks plan</h2>
        <p class="mt-4 text-lg text-slate-600">Van basishosting tot actieve lokale groei. Elk plan bouwt voort op het vorige.</p>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">

        <article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div class="flex items-center gap-3">
            <span class="text-3xl">&#128737;</span>
            <div>
              <h3 class="text-xl font-semibold leading-tight text-slate-900">Zorgeloos</h3>
              <span class="mt-1 inline-block rounded-full bg-[#006633]/10 px-3 py-0.5 text-xs font-medium uppercase tracking-wide text-[#006633]">Verplicht &middot; hoort bij elke site</span>
            </div>
          </div>
          <div class="mt-5 flex items-baseline gap-2">
            <span class="text-4xl font-bold text-slate-900">&euro;10</span>
            <span class="text-slate-500">/mnd</span>
            <span class="ml-2 text-sm text-slate-500">of &euro;100/jaar</span>
          </div>
          <p class="mt-1 text-sm text-[#006633] font-medium">Jaarlijks = 2 maanden voordeel</p>
          <p class="mt-4 text-slate-700">Zorgt dat je site online, veilig en bereikbaar blijft.</p>
          <ul class="mt-6 flex-1 space-y-3 text-slate-600">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Snelle, veilige hosting + SSL</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Domeinkoppeling en verlenging bewaakt</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Automatische backups</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Uptime-monitoring</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Software- en beveiligingsupdates</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Een mens die opneemt als er iets is</li>
          </ul>
          <a href="/contact" class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">Kies Zorgeloos</a>
        </article>

        <article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div class="flex items-center gap-3">
            <span class="text-3xl">&#127807;</span>
            <div>
              <h3 class="text-xl font-semibold leading-tight text-slate-900">Groei &mdash; Licht</h3>
              <span class="mt-1 inline-block rounded-full bg-[#006633]/10 px-3 py-0.5 text-xs font-medium uppercase tracking-wide text-[#006633]">Gevonden blijven worden</span>
            </div>
          </div>
          <div class="mt-5 flex items-baseline gap-2">
            <span class="text-4xl font-bold text-slate-900">&plusmn;&nbsp;&euro;99</span>
            <span class="text-slate-500">/mnd</span>
          </div>
          <p class="mt-4 text-slate-700">Voor wie gevonden wil blijven worden. Wij houden de motor draaiend.</p>
          <ul class="mt-6 flex-1 space-y-3 text-slate-600">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Alles uit Zorgeloos</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> 2 SEO-blogs per maand</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Google Bedrijfsprofiel onderhouden</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Kleine tekstwijzigingen inbegrepen</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Kwartaalrapport + update</li>
          </ul>
          <a href="/contact" class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">Kies Groei Licht</a>
        </article>

        <article class="group relative flex flex-col overflow-hidden rounded-2xl border-2 border-[#7C3AED] bg-white p-8 shadow-lg transition hover:-translate-y-1 hover:shadow-xl">
          <div class="absolute right-6 top-6 rounded-full bg-[#7C3AED] px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">Populair</div>
          <div class="flex items-center gap-3">
            <span class="text-3xl">&#128640;</span>
            <div>
              <h3 class="text-xl font-semibold leading-tight text-slate-900">Groei &mdash; Actief</h3>
              <span class="mt-1 inline-block rounded-full bg-[#7C3AED]/10 px-3 py-0.5 text-xs font-medium uppercase tracking-wide text-[#7C3AED]">Marktaandeel pakken</span>
            </div>
          </div>
          <div class="mt-5 flex items-baseline gap-2">
            <span class="text-4xl font-bold text-slate-900">&plusmn;&nbsp;&euro;249</span>
            <span class="text-slate-500">/mnd</span>
          </div>
          <p class="mt-4 text-slate-700">Voor wie echt wil groeien en marktaandeel pakt.</p>
          <ul class="mt-6 flex-1 space-y-3 text-slate-600">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Alles uit Licht</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> 2&ndash;4 blogs per maand</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Nieuwe lokale- en dienstpagina's</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Actieve lokale SEO / Google Maps</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Maandrapport + maandelijks contact</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-[#006633]">&#10003;</span> Voorrang op wijzigingen</li>
          </ul>
          <a href="/contact" class="mt-6 inline-flex w-full items-center justify-center rounded-lg bg-[#7C3AED] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#6D28D9]">Kies Groei Actief</a>
        </article>

      </div>
    </div>
  </section>

  <!-- Waarom maandelijks -->
  <section class="bg-white py-20">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
        <div>
          <span class="section-label">Waarom maandelijks?</span>
          <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Online succes is geen eenmalig project</h2>
          <p class="mt-4 text-lg text-slate-600">Een nieuwe website is een goed begin. Maar Google beloont websites die regelmatig worden bijgewerkt. Concurrenten posten blogs, verbeteren hun pagina's en verzamelen reviews. Wie stilstaat, zakt.</p>
          <p class="mt-4 text-slate-600">Met onze maandelijkse werkzaamheden hoef jij daar niet aan te denken.</p>
          <a href="/contact" class="mt-8 inline-flex rounded-lg bg-[#006633] px-7 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">Bespreek jouw situatie</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <p class="font-semibold text-slate-900">Vast aanspreekpunt</p>
            <p class="mt-2 text-sm text-slate-600">Je werkt altijd met dezelfde persoon.</p>
          </div>
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <p class="font-semibold text-slate-900">Maandelijkse rapportage</p>
            <p class="mt-2 text-sm text-slate-600">Je ziet precies wat we gedaan hebben.</p>
          </div>
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <p class="font-semibold text-slate-900">Altijd actueel</p>
            <p class="mt-2 text-sm text-slate-600">Up-to-date met de nieuwste beveiligings- en SEO-standaarden.</p>
          </div>
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <p class="font-semibold text-slate-900">Schaalbaar</p>
            <p class="mt-2 text-sm text-slate-600">Start met Zorgeloos en groei mee naar Actief.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-slate-50 py-20">
    <div class="container">
      <div class="max-w-2xl mb-10">
        <span class="section-label">Veelgestelde vragen</span>
        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Vragen over maandelijkse werkzaamheden</h2>
      </div>
      <div class="max-w-3xl space-y-4">
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Moet ik een plan afnemen als ik een website laat maken?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">Het Zorgeloos-plan (€10/mnd) is verplicht — dit dekt de hosting en het onderhoud. De Groei-plannen zijn optioneel.</p>
        </details>
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Kan ik stoppen of wisselen van plan?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">Ja. Upgraden kan direct; downgraden gaat in per volgende maand. Geen boetes of verborgen kosten.</p>
        </details>
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Schrijven jullie ook de blogs voor mij?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">Ja. Bij Groei Licht en Groei Actief schrijven wij de blogs volledig, gericht op lokale zoekwoorden in jouw branche.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#006633] py-20">
    <div class="container text-center">
      <h2 class="text-4xl font-semibold text-white">Laat jouw website voor je werken — elke maand</h2>
      <p class="mt-4 text-xl text-white/80">Bespreek welk plan het beste bij jouw bedrijf past. Gratis en vrijblijvend.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="inline-flex rounded-lg bg-white px-8 py-4 text-sm font-semibold text-[#006633] transition hover:bg-slate-100">Plan een gratis gesprek</a>
        <a href="/website-laten-maken" class="inline-flex rounded-lg border border-white/30 px-8 py-4 text-sm font-semibold text-white transition hover:bg-white/10">Website laten maken</a>
      </div>
    </div>
  </section>

</BaseLayout>
