---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Website onderhoud | VB-DigitalMarketing';
const description = 'Professioneel website onderhoud voor een veilige, snelle en up-to-date website. Wij zorgen voor updates, backups en optimalisaties zodat jij je kunt focussen op je werk.';
---
<BaseLayout {title} {description}>

  <!-- Hero -->
  <section class="relative min-h-screen overflow-hidden bg-[#006633] flex items-center">
    <div class="absolute right-0 top-0 hidden h-full w-1/2 lg:block">
      <img src="/images/hero-bg.jpeg" alt="Website onderhoud" class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#006633] via-[#006633]/60 to-transparent"></div>
    </div>
    <div class="container relative z-10 py-24 lg:py-0">
      <div class="max-w-xl">
        <span class="inline-flex rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.3em] text-white">Website onderhoud</span>
        <h1 class="mt-6 text-5xl font-bold tracking-tight text-white lg:text-6xl">
          Jouw website altijd veilig, snel en up-to-date
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-8 text-white/80">
          Wij zorgen voor het volledige beheer van jouw website. Van beveiligingsupdates tot prestatie-optimalisaties — jij focust op je vak, wij houden je site in topconditie.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href="/contact" class="btn-brand">Plan een gesprek</a>
          <a href="/cases" class="btn-ghost">Bekijk voorbeelden</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Reviews — compact -->
  <section class="bg-white py-8 border-b border-slate-100">
    <div class="container">
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-2.5 rounded-xl border border-slate-200 bg-slate-50 px-5 py-3">
          <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span class="text-sm font-semibold text-slate-700">Google Reviews</span>
          <span class="text-yellow-400 text-base leading-none">★★★★★</span>
          <span class="text-sm font-bold text-slate-900">4.9</span>
          <span class="text-sm text-slate-400">/ 18 beoordelingen</span>
        </div>
        <p class="text-sm text-slate-500 italic">"Geen zorgen meer over mijn website — ze regelen alles." — Peter Smits</p>
        <p class="hidden text-sm text-slate-500 italic md:block">"Altijd snel gereageerd bij een probleem." — Lisa van den Berg</p>
      </div>
    </div>
  </section>

  <!-- Wat je krijgt — foto links, opsomming rechts -->
  <section class="bg-white py-20">
    <div class="container">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-sm lg:grid lg:grid-cols-2">
        <div class="relative min-h-[320px] lg:min-h-full">
          <img
            src="/images/about-story.jpeg"
            alt="Website onderhoud en beheer"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#006633]/40 to-transparent lg:bg-gradient-to-r lg:from-transparent lg:to-slate-50/10"></div>
        </div>
        <div class="flex flex-col justify-center px-10 py-14">
          <span class="section-label">Wat is inbegrepen</span>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-slate-900">
            Compleet websitebeheer zonder zorgen
          </h2>
          <p class="mt-4 text-slate-600">
            Wij nemen het volledige technische beheer van jouw website over. Zodat jij nooit meer wakker ligt over een gehackte site, trage laadtijd of verlopen domein.
          </p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-center gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#006633] text-xs text-white">&#10003;</span>
              <span class="font-medium text-slate-800">Maandelijkse beveiligings- en software-updates</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#006633] text-xs text-white">&#10003;</span>
              <span class="font-medium text-slate-800">Automatische dagelijkse backups</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#006633] text-xs text-white">&#10003;</span>
              <span class="font-medium text-slate-800">Uptime-monitoring 24/7</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#006633] text-xs text-white">&#10003;</span>
              <span class="font-medium text-slate-800">Snelheids- en prestatieoptimalisatie</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#006633] text-xs text-white">&#10003;</span>
              <span class="font-medium text-slate-800">SSL-certificaat beheer</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#006633] text-xs text-white">&#10003;</span>
              <span class="font-medium text-slate-800">Persoonlijk aanspreekpunt bij problemen</span>
            </li>
          </ul>
          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class="btn-brand">Plan een gesprek</a>
            <a href="/maandelijkse-werkzaamheden" class="inline-flex items-center justify-center rounded-lg border border-[#006633] px-6 py-3 text-sm font-semibold text-[#006633] transition hover:bg-[#006633]/5">Bekijk maandpakketten</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Waarom onderhoud belangrijk is -->
  <section class="bg-slate-50 py-20">
    <div class="container">
      <div class="max-w-2xl mb-12">
        <span class="section-label">Waarom onderhoud?</span>
        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Een website zonder onderhoud is een risico</h2>
        <p class="mt-4 text-lg text-slate-600">Verouderde software, beveiligingslekken en trage laadtijden kosten je bezoekers en klanten. Wij voorkomen dat.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <span class="text-3xl">&#128737;</span>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">Veiligheid</h3>
          <p class="mt-2 text-slate-600">Websites zonder updates zijn het doelwit van hackers. Wij houden jouw site beveiligd met de nieuwste patches.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <span class="text-3xl">&#9889;</span>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">Snelheid</h3>
          <p class="mt-2 text-slate-600">Een trage website verliest bezoekers. Wij optimaliseren regelmatig de laadsnelheid zodat jij bezoekers vasthoudt.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <span class="text-3xl">&#128200;</span>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">Google ranking</h3>
          <p class="mt-2 text-slate-600">Google beloont goed onderhouden websites met een hogere positie. Slecht onderhoud kost je vindbaarheid.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <span class="text-3xl">&#128260;</span>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">Automatische backups</h3>
          <p class="mt-2 text-slate-600">Bij een storing of hack kun je altijd terugvallen op een recente backup. Nooit meer dataverlies.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <span class="text-3xl">&#128241;</span>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">Mobiel klaar</h3>
          <p class="mt-2 text-slate-600">We controleren regelmatig of jouw site op alle apparaten goed werkt en passen aan waar nodig.</p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <span class="text-3xl">&#128105;&#8205;&#128187;</span>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">Vast aanspreekpunt</h3>
          <p class="mt-2 text-slate-600">Eén persoon die jouw website kent en direct beschikbaar is als er iets niet klopt.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Onderhoudspakketten -->
  <section class="bg-white py-20">
    <div class="container">
      <div class="max-w-2xl mb-12">
        <span class="section-label">Onderhoudspakketten</span>
        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Kies jouw onderhoudspakket</h2>
        <p class="mt-4 text-lg text-slate-600">Van basisbeheer tot actieve groeiondersteuning. Elk pakket zorgt dat jouw website optimaal blijft presteren.</p>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">

        <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#006633]/10 text-2xl">&#128737;</div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">Basis</h3>
          <p class="mt-2 text-slate-600">Technisch beheer zonder zorgen.</p>
          <div class="mt-5 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-slate-900">&euro;29</span>
            <span class="text-slate-500">/mnd</span>
          </div>
          <ul class="mt-7 flex-1 space-y-3 text-sm text-slate-600">
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Software- en plug-in updates</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Dagelijkse backup</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Uptime-monitoring</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> SSL-beheer</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Maandrapportage</li>
          </ul>
          <a href="/contact" class="mt-8 inline-flex w-full justify-center rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">Kies Basis</a>
        </article>

        <article class="relative flex flex-col rounded-2xl border-2 border-[#7C3AED] bg-white p-8 shadow-lg transition hover:-translate-y-1 hover:shadow-xl">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-[#7C3AED] px-4 py-2 text-xs font-bold text-white">Meest gekozen</div>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#7C3AED]/10 text-2xl">&#127807;</div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">Comfort</h3>
          <p class="mt-2 text-slate-600">Beheer én kleine aanpassingen inbegrepen.</p>
          <div class="mt-5 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-slate-900">&euro;59</span>
            <span class="text-slate-500">/mnd</span>
          </div>
          <ul class="mt-7 flex-1 space-y-3 text-sm text-slate-600">
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Alles uit Basis</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Tot 1 uur aanpassingen/mnd</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Snelheidsoptimalisatie</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Prioriteit support</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Kwartaalgesprek</li>
          </ul>
          <a href="/contact" class="mt-8 inline-flex w-full justify-center rounded-lg bg-[#7C3AED] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#6D28D9]">Kies Comfort</a>
        </article>

        <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#006633]/10 text-2xl">&#128640;</div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">Pro</h3>
          <p class="mt-2 text-slate-600">Volledig ontzorgd, inclusief content en SEO.</p>
          <div class="mt-5 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-slate-900">&euro;129</span>
            <span class="text-slate-500">/mnd</span>
          </div>
          <ul class="mt-7 flex-1 space-y-3 text-sm text-slate-600">
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Alles uit Comfort</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Tot 3 uur aanpassingen/mnd</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Maandelijkse SEO-check</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Google Analytics rapportage</li>
            <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Maandelijks overleg</li>
          </ul>
          <a href="/contact" class="mt-8 inline-flex w-full justify-center rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">Kies Pro</a>
        </article>

      </div>
    </div>
  </section>

  <!-- Hoe het werkt -->
  <section class="bg-[#006633] py-20 text-white">
    <div class="container">
      <div class="mb-12 max-w-2xl">
        <p class="text-sm uppercase tracking-[0.28em] text-white/70">Werkwijze</p>
        <h2 class="mt-4 text-4xl font-semibold">Zo werkt websiteonderhoud bij ons</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1">
          <span class="text-sm uppercase tracking-[0.28em] text-white/60">Stap 1</span>
          <h3 class="mt-3 text-xl font-semibold">Intake</h3>
          <p class="mt-2 text-sm text-slate-300">We bekijken jouw huidige website en bespreken wat er nodig is.</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1">
          <span class="text-sm uppercase tracking-[0.28em] text-white/60">Stap 2</span>
          <h3 class="mt-3 text-xl font-semibold">Overdracht</h3>
          <p class="mt-2 text-sm text-slate-300">We nemen de toegangen over en voeren een eerste audit uit.</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1">
          <span class="text-sm uppercase tracking-[0.28em] text-white/60">Stap 3</span>
          <h3 class="mt-3 text-xl font-semibold">Maandelijks beheer</h3>
          <p class="mt-2 text-sm text-slate-300">We voeren updates uit, controleren de prestaties en rapporteren.</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1">
          <span class="text-sm uppercase tracking-[0.28em] text-white/60">Stap 4</span>
          <h3 class="mt-3 text-xl font-semibold">Doorgroeien</h3>
          <p class="mt-2 text-sm text-slate-300">We adviseren proactief over verbeteringen om jouw site te laten groeien.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-slate-50 py-20">
    <div class="container">
      <div class="max-w-2xl mb-10">
        <span class="section-label">Veelgestelde vragen</span>
        <h2 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Vragen over website onderhoud</h2>
      </div>
      <div class="max-w-3xl space-y-4">
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Nemen jullie ook bestaande websites over?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">Ja. We nemen elke bestaande website over na een korte audit. We kijken wat er nodig is en starten vervolgens met het beheer.</p>
        </details>
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Hoe snel reageren jullie bij een storing?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">Bij het Comfort- en Pro-pakket hebben storingen prioriteit. We streven naar een reactie binnen 4 uur op werkdagen.</p>
        </details>
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Kan ik een onderhoudspakket combineren met een nieuw websiteproject?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">Absoluut. Als wij de website bouwen, gaat het onderhoud daarna naadloos door. Je krijgt altijd korting als je combineert.</p>
        </details>
        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between text-lg font-semibold text-slate-900">
            Zit er een contract aan vast?
            <span class="ml-4 shrink-0 text-[#006633] transition group-open:rotate-45">&#43;</span>
          </summary>
          <p class="mt-4 text-slate-600">We werken met een maandelijks opzegbaar abonnement. Geen langlopende contracten of verborgen kosten.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#006633] py-20">
    <div class="container text-center">
      <h2 class="text-4xl font-semibold text-white">Klaar om je website in goede handen te geven?</h2>
      <p class="mt-4 text-xl text-white/80">Plan een gratis gesprek en ontdek welk pakket het beste bij jou past.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/contact" class="inline-flex rounded-lg bg-white px-8 py-4 text-sm font-semibold text-[#006633] transition hover:bg-slate-100">Plan een gratis gesprek</a>
        <a href="/maandelijkse-werkzaamheden" class="inline-flex rounded-lg border border-white/30 px-8 py-4 text-sm font-semibold text-white transition hover:bg-white/10">Bekijk maandpakketten</a>
      </div>
    </div>
  </section>

</BaseLayout>
