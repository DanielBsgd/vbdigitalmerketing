---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaveDivider from '../components/WaveDivider.astro';
const title = 'Pakketten | VB-DigitalMarketing';
const description = 'Duidelijke pakketten voor lokale ondernemers: websites, SEO en content op maat.';
---
<BaseLayout {title} {description}>
  <section class="bg-[#006633] py-20">
    <div class="container">
      <div class="max-w-2xl">
        <span class="inline-flex rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.3em] text-white">Pakketten</span>
        <h1 class="mt-6 text-5xl font-semibold tracking-tight text-white">Kies jouw pakket</h1>
        <p class="mt-6 text-lg leading-8 text-white/80">Van een compacte starter-site tot volledige online zichtbaarheid. Elk pakket is afgestemd op jouw bedrijf en regio.</p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href="/contact" class="btn-brand">Neem contact op</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pakketten -->
  <section class="bg-slate-50 py-20">
    <div class="container">
      <div class="grid gap-8 lg:grid-cols-3">

        <article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div class="relative h-48 overflow-hidden bg-slate-100">
            <img src="/images/block-website.svg" alt="Starter pakket" class="h-full w-full object-cover" />
          </div>
          <div class="flex flex-1 flex-col p-8">
            <span class="text-xs font-semibold uppercase tracking-[0.24em] text-[#006633]">Beginnen</span>
            <h2 class="mt-3 text-2xl font-semibold text-slate-900">Starter</h2>
            <p class="mt-3 text-slate-600">Snel online met een sterke eerste site.</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-slate-900">&euro;699</span>
            </div>
            <ul class="mt-8 flex-1 space-y-3 text-sm text-slate-600">
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> 1-pagina website</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Contactformulier</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Basis SEO</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Snelle oplevering</li>
            </ul>
            <a href="/contact" class="mt-8 inline-flex w-full justify-center rounded-lg bg-[#7C3AED] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#6D28D9]">Kies Starter</a>
          </div>
        </article>

        <article class="group relative flex flex-col overflow-hidden rounded-2xl border-2 border-[#7C3AED] bg-white shadow-lg transition hover:-translate-y-1 hover:shadow-xl">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 inline-flex rounded-full bg-[#7C3AED] px-4 py-2 text-xs font-semibold text-white whitespace-nowrap">
            Meest gekozen
          </div>
          <div class="relative h-48 overflow-hidden bg-slate-100">
            <img src="/images/block-seo.svg" alt="Pro pakket" class="h-full w-full object-cover" />
          </div>
          <div class="flex flex-1 flex-col p-8 pt-10">
            <span class="text-xs font-semibold uppercase tracking-[0.24em] text-[#7C3AED]">Populair</span>
            <h2 class="mt-3 text-2xl font-semibold text-slate-900">Pro</h2>
            <p class="mt-3 text-slate-600">De perfecte balans tussen zichtbaarheid en content.</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-slate-900">&euro;1.499</span>
            </div>
            <ul class="mt-8 flex-1 space-y-3 text-sm text-slate-600">
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Tot 6 pagina's</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Lokale SEO (3 regio's)</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Content &amp; foto's</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Contact &amp; integratie</li>
            </ul>
            <a href="/contact" class="mt-8 inline-flex w-full justify-center rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#07512a]">Kies Pro</a>
          </div>
        </article>

        <article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div class="relative h-48 overflow-hidden bg-slate-100">
            <img src="/images/block-content.svg" alt="Growth pakket" class="h-full w-full object-cover" />
          </div>
          <div class="flex flex-1 flex-col p-8">
            <span class="text-xs font-semibold uppercase tracking-[0.24em] text-[#006633]">Schalen</span>
            <h2 class="mt-3 text-2xl font-semibold text-slate-900">Growth</h2>
            <p class="mt-3 text-slate-600">Meerdere regio's en groeiende content.</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class="text-4xl font-bold text-slate-900">&euro;2.999</span>
            </div>
            <ul class="mt-8 flex-1 space-y-3 text-sm text-slate-600">
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Tot 12 pagina's</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Lokale landingspagina's</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Maandelijks onderhoud</li>
              <li class="flex items-start gap-2"><span class="text-[#006633]">&#10003;</span> Volledige support</li>
            </ul>
            <a href="/contact" class="mt-8 inline-flex w-full justify-center rounded-lg bg-[#7C3AED] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#6D28D9]">Kies Growth</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- How to start -->
  <section class="bg-[#006633] py-20 text-white">
    <div class="container">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-10 shadow-2xl">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
          <div>
            <p class="text-sm uppercase tracking-[0.28em] text-white/70">Hoe het werkt</p>
            <h2 class="mt-4 text-4xl font-semibold text-white">Online groeien in 4 stappen</h2>
            <p class="mt-4 max-w-2xl text-slate-200">Begin vandaag met een website die klanten activeert en kies een pakket dat past bij jouw regio.</p>
          </div>
          <div class="space-y-4">
            <div class="rounded-xl border border-white/10 bg-white/10 p-5 transition hover:-translate-y-1 hover:bg-white/15">
              <span class="text-sm uppercase tracking-[0.28em] text-white/70">Stap 1</span>
              <h3 class="mt-3 text-xl font-semibold text-white">Jouw doel bepalen</h3>
              <p class="mt-2 text-slate-200">We kijken naar jouw klanten, regio en wat je wilt bereiken.</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/10 p-5 transition hover:-translate-y-1 hover:bg-white/15">
              <span class="text-sm uppercase tracking-[0.28em] text-white/70">Stap 2</span>
              <h3 class="mt-3 text-xl font-semibold text-white">Website &amp; regio</h3>
              <p class="mt-2 text-slate-200">Je krijgt een website met lokale focus en duidelijke dienstpagina's.</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/10 p-5 transition hover:-translate-y-1 hover:bg-white/15">
              <span class="text-sm uppercase tracking-[0.28em] text-white/70">Stap 3</span>
              <h3 class="mt-3 text-xl font-semibold text-white">SEO &amp; content</h3>
              <p class="mt-2 text-slate-200">Jouw website krijgt de juiste content en zoekwoorden voor klanten in de buurt.</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/10 p-5 transition hover:-translate-y-1 hover:bg-white/15">
              <span class="text-sm uppercase tracking-[0.28em] text-white/70">Stap 4</span>
              <h3 class="mt-3 text-xl font-semibold text-white">Live &amp; groeien</h3>
              <p class="mt-2 text-slate-200">Je website gaat live en we blijven verbeteren om meer aanvragen te krijgen.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wat zit in elk pakket -->
  <section class="bg-white py-20">
    <div class="container">
      <div class="mb-10 rounded-2xl border border-slate-200 bg-slate-50 p-10 transition hover:-translate-y-1 hover:shadow-xl">
        <h2 class="text-3xl font-semibold text-slate-900">Twijfel je nog?</h2>
        <p class="mt-4 max-w-3xl text-lg text-slate-700">We helpen je graag. Neem contact op en we bespreken welk pakket het beste past bij jouw regio en doelen.</p>
        <a href="/contact" class="mt-8 inline-flex rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#07512a]">Plan een consult</a>
      </div>

      <h2 class="text-3xl font-semibold text-slate-900">Wat zit in elk pakket?</h2>
      <p class="mt-2 text-slate-600">Ongeacht welk pakket je kiest, dit krijg je altijd:</p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <p class="font-semibold text-slate-900">Persoonlijk intakegesprek</p>
          <p class="mt-3 text-sm text-slate-600">We begrijpen jouw bedrijf en doelen eerst.</p>
        </div>
        <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <p class="font-semibold text-slate-900">Snelle oplevering</p>
          <p class="mt-3 text-sm text-slate-600">Heldere planning en geen overbodige wachttijden.</p>
        </div>
        <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <p class="font-semibold text-slate-900">Mobiel &amp; snel</p>
          <p class="mt-3 text-sm text-slate-600">Je website laadt razendsnel op alle apparaten.</p>
        </div>
        <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <p class="font-semibold text-slate-900">Duidelijke contactroute</p>
          <p class="mt-3 text-sm text-slate-600">Bezoekers weten precies hoe ze contact maken.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
