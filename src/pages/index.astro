---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CaseCard from '../components/CaseCard.astro';
import WaveDivider from '../components/WaveDivider.astro';

const title = 'VB-DigitalMarketing — Websites voor vakmensen';
const description = 'We bouwen duidelijke, snelle websites voor schilders, timmermannen, loodgieters en coaches. Gericht op leads en lokale vindbaarheid.';
---

<BaseLayout {title} {description}>

  <!-- Hero -->
  <section class="bg-white">
    <Hero
      eyebrow="Voor vakmensen"
      title="Websites die jouw vakmanschap laten spreken"
      description="Snel live, persoonlijk en geoptimaliseerd voor lokale vindbaarheid. We bouwen websites die klanten begrijpen en aanzetten tot contact."
      ctaText="Kennismaken"
      ctaHref="/contact"
      image="/images/hero-bg.jpeg"
    />
  </section>

  <!-- Stats balk -->
  <section class="border-b border-slate-100 bg-white py-10">
    <div class="container">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
        <div class="text-center">
          <p class="text-4xl font-black text-[#006633]">50+</p>
          <p class="mt-1 text-sm font-medium text-slate-500">Websites gebouwd</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-black text-[#006633]">4.9</p>
          <p class="mt-1 text-sm font-medium text-slate-500">Google beoordeling</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-black text-[#006633]">2 wkn</p>
          <p class="mt-1 text-sm font-medium text-slate-500">Gemiddelde levertijd</p>
        </div>
        <div class="text-center">
          <p class="text-4xl font-black text-[#006633]">100%</p>
          <p class="mt-1 text-sm font-medium text-slate-500">Persoonlijke aanpak</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Marquee ticker ───────────────────────────────────── -->
  <div class="marquee-wrap overflow-hidden border-y border-slate-100 bg-white py-4 select-none">
    <!-- Rij 1 — scrollt naar links -->
    <div class="flex" style="width:max-content">
      <div class="marquee-l flex items-center" style="width:max-content">
        <span class="flex shrink-0 items-center whitespace-nowrap text-xs font-extrabold uppercase tracking-[0.22em] text-slate-700 sm:text-sm">
          VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>&nbsp;
        </span>
        <span class="flex shrink-0 items-center whitespace-nowrap text-xs font-extrabold uppercase tracking-[0.22em] text-slate-700 sm:text-sm" aria-hidden="true">
          VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>VINDBAARHEID<span class="mx-5 text-[#7C3AED]">&bull;</span>DIVI<span class="mx-5 text-[#7C3AED]">&bull;</span>ELEMENTOR<span class="mx-5 text-[#7C3AED]">&bull;</span>SUPPORT<span class="mx-5 text-[#7C3AED]">&bull;</span>AI<span class="mx-5 text-[#7C3AED]">&bull;</span>&nbsp;
        </span>
      </div>
    </div>

    <!-- Rij 2 — scrollt naar rechts -->
    <div class="mt-3 flex" style="width:max-content">
      <div class="marquee-r flex items-center" style="width:max-content">
        <span class="flex shrink-0 items-center whitespace-nowrap text-xs font-extrabold uppercase tracking-[0.22em] text-slate-400 sm:text-sm">
          WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>&nbsp;
        </span>
        <span class="flex shrink-0 items-center whitespace-nowrap text-xs font-extrabold uppercase tracking-[0.22em] text-slate-400 sm:text-sm" aria-hidden="true">
          WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>WORDPRESS<span class="mx-5 text-[#006633]">&bull;</span>SHOPIFY<span class="mx-5 text-[#006633]">&bull;</span>CUSTOM&nbsp;CODE<span class="mx-5 text-[#006633]">&bull;</span>UX/UI<span class="mx-5 text-[#006633]">&bull;</span>&nbsp;
        </span>
      </div>
    </div>
  </div>

  <!-- Feature kaarten — genummerd, professioneel -->
  <section class="bg-white py-24">
    <div class="container">
      <div class="mb-14 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <span class="section-label">Waarom VB-DigitalMarketing</span>
          <h2 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 lg:text-5xl">Jouw website.<br class="hidden lg:block" />Onze expertise.</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/website-laten-maken" class="btn-brand">Website laten maken</a>
          <a href="/contact" class="btn-outline-green">Plan een afspraak</a>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">

        <div class="pro-shadow luxury-card group relative flex flex-col overflow-hidden rounded-2xl bg-white p-8">
          <span class="absolute right-6 top-5 text-7xl font-black leading-none text-[#006633]/[0.07] select-none">01</span>
          <div class="mb-5 h-1 w-10 rounded-full bg-[#006633]"></div>
          <h3 class="text-xl font-bold text-slate-900">Professionele eerste indruk</h3>
          <p class="mt-3 flex-1 text-slate-500 text-sm leading-relaxed">Een website die meteen vertrouwen wekt en laat zien waarom klanten jou moeten kiezen.</p>
          <a href="/website-laten-maken" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#006633] transition hover:gap-3">
            Lees meer <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="pro-shadow luxury-card group relative flex flex-col overflow-hidden rounded-2xl bg-white p-8" style="border-color:rgba(124,58,237,0.28)!important">
          <span class="absolute right-6 top-5 text-7xl font-black leading-none text-[#7C3AED]/[0.08] select-none">02</span>
          <div class="mb-5 h-1 w-10 rounded-full bg-[#7C3AED]"></div>
          <h3 class="text-xl font-bold text-slate-900">Lokale vindbaarheid</h3>
          <p class="mt-3 flex-1 text-slate-500 text-sm leading-relaxed">Pagina's voor jouw stad of regio — zodat klanten om de hoek jou als eerste vinden.</p>
          <a href="/website-laten-maken" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#7C3AED] transition hover:gap-3">
            Lees meer <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="pro-shadow luxury-card group relative flex flex-col overflow-hidden rounded-2xl bg-white p-8">
          <span class="absolute right-6 top-5 text-7xl font-black leading-none text-[#006633]/[0.07] select-none">03</span>
          <div class="mb-5 h-1 w-10 rounded-full bg-[#006633]"></div>
          <h3 class="text-xl font-bold text-slate-900">Heldere samenwerking</h3>
          <p class="mt-3 flex-1 text-slate-500 text-sm leading-relaxed">Korte feedbackrondes en duidelijke keuzes — geen verrassingen, wel een top eindresultaat.</p>
          <a href="/over-ons" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#006633] transition hover:gap-3">
            Lees meer <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="pro-shadow luxury-card group relative flex flex-col overflow-hidden rounded-2xl bg-white p-8" style="border-color:rgba(124,58,237,0.28)!important">
          <span class="absolute right-6 top-5 text-7xl font-black leading-none text-[#7C3AED]/[0.08] select-none">04</span>
          <div class="mb-5 h-1 w-10 rounded-full bg-[#7C3AED]"></div>
          <h3 class="text-xl font-bold text-slate-900">Meer aanvragen</h3>
          <p class="mt-3 flex-1 text-slate-500 text-sm leading-relaxed">Een website die ontworpen is om contactaanvragen en telefoontjes binnen te laten komen.</p>
          <a href="/contact" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[#7C3AED] transition hover:gap-3">
            Lees meer <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Expertises slider ───────────────────────────────────── -->
  <section class="relative overflow-hidden bg-[#006633] py-20">
    <div class="absolute -left-40 -top-40 h-[480px] w-[480px] rounded-full bg-white/[0.04] blur-3xl pointer-events-none"></div>
    <div class="absolute -right-40 bottom-0 h-[480px] w-[480px] rounded-full bg-white/[0.04] blur-3xl pointer-events-none"></div>

    <div class="container relative">
      <div class="mb-12 text-center">
        <span class="inline-flex rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.3em] text-white">Onze expertises</span>
        <h2 class="mt-4 text-4xl font-semibold text-white">Wat kunnen wij voor je doen?</h2>
        <p class="mt-3 text-white/70">Scroll door onze vier kernexpertises</p>
      </div>

      <!-- Slider wrapper -->
      <div class="relative">
        <div class="overflow-hidden rounded-3xl shadow-2xl" id="exp-wrap">
          <div class="flex" id="exp-track" style="transition: transform 0.55s cubic-bezier(0.25,1,0.5,1);">

            <!-- Slide 1 -->
            <div class="min-w-full">
              <div class="grid items-stretch lg:grid-cols-2">
                <div class="relative min-h-[240px] lg:min-h-[400px]">
                  <img src="/images/hero-bg.jpeg" alt="Website laten maken" class="absolute inset-0 h-full w-full object-cover" />
                  <div class="absolute inset-0 bg-black/20"></div>
                </div>
                <div class="flex flex-col justify-center bg-white p-10 lg:p-14">
                  <span class="text-xs font-bold uppercase tracking-[0.28em] text-[#006633]">01 &mdash; 04</span>
                  <h3 class="mt-3 text-3xl font-bold text-slate-900">Website laten maken</h3>
                  <p class="mt-4 leading-relaxed text-slate-600">Wij bouwen professionele websites voor vakmensen die lokaal gevonden willen worden. Snel online, op maat en meetbaar effectief.</p>
                  <a href="/website-laten-maken" class="mt-8 self-start inline-flex items-center gap-2 rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">
                    Meer info
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Slide 2 -->
            <div class="min-w-full">
              <div class="grid items-stretch lg:grid-cols-2">
                <div class="relative min-h-[240px] lg:min-h-[400px]">
                  <img src="/images/about-story.jpeg" alt="Maandelijkse werkzaamheden" class="absolute inset-0 h-full w-full object-cover" />
                  <div class="absolute inset-0 bg-black/20"></div>
                </div>
                <div class="flex flex-col justify-center bg-white p-10 lg:p-14">
                  <span class="text-xs font-bold uppercase tracking-[0.28em] text-[#006633]">02 &mdash; 04</span>
                  <h3 class="mt-3 text-3xl font-bold text-slate-900">Maandelijkse werkzaamheden</h3>
                  <p class="mt-4 leading-relaxed text-slate-600">SEO-blogs, Google Bedrijfsprofiel en content — wij zorgen elke maand dat jouw website blijft groeien en nieuwe klanten aantrekt.</p>
                  <a href="/maandelijkse-werkzaamheden" class="mt-8 self-start inline-flex items-center gap-2 rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">
                    Meer info
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Slide 3 -->
            <div class="min-w-full">
              <div class="grid items-stretch lg:grid-cols-2">
                <div class="relative min-h-[240px] lg:min-h-[400px]">
                  <img src="/images/hero-bg.jpeg" alt="Website onderhoud" class="absolute inset-0 h-full w-full object-cover" />
                  <div class="absolute inset-0 bg-[#006633]/50"></div>
                </div>
                <div class="flex flex-col justify-center bg-white p-10 lg:p-14">
                  <span class="text-xs font-bold uppercase tracking-[0.28em] text-[#006633]">03 &mdash; 04</span>
                  <h3 class="mt-3 text-3xl font-bold text-slate-900">Website onderhoud</h3>
                  <p class="mt-4 leading-relaxed text-slate-600">Updates, backups en uptime-monitoring. Wij houden jouw website veilig en snel — zonder dat jij er aan hoeft te denken.</p>
                  <a href="/website-onderhoud" class="mt-8 self-start inline-flex items-center gap-2 rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">
                    Meer info
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>

            <!-- Slide 4 -->
            <div class="min-w-full">
              <div class="grid items-stretch lg:grid-cols-2">
                <div class="relative min-h-[240px] lg:min-h-[400px]">
                  <img src="/images/image00008.jpeg" alt="Hosting en domeinnaam" class="absolute inset-0 h-full w-full object-cover" />
                  <div class="absolute inset-0 bg-black/20"></div>
                </div>
                <div class="flex flex-col justify-center bg-white p-10 lg:p-14">
                  <span class="text-xs font-bold uppercase tracking-[0.28em] text-[#006633]">04 &mdash; 04</span>
                  <h3 class="mt-3 text-3xl font-bold text-slate-900">Hosting &amp; domeinnaam</h3>
                  <p class="mt-4 leading-relaxed text-slate-600">Van domeinnaamregistratie tot snelle SSD-hosting met SSL. Wij regelen het volledig zodat jouw site altijd bereikbaar is.</p>
                  <a href="/website-hosting-en-domeinnaam" class="mt-8 self-start inline-flex items-center gap-2 rounded-lg bg-[#006633] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#004d26]">
                    Meer info
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- Pijlen -->
        <button id="exp-prev" aria-label="Vorige" class="absolute left-3 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-xl text-slate-700 transition hover:bg-[#006633] hover:text-white lg:-left-6">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="exp-next" aria-label="Volgende" class="absolute right-3 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-xl text-slate-700 transition hover:bg-[#006633] hover:text-white lg:-right-6">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>

      <!-- Dots -->
      <div class="mt-8 flex justify-center gap-2.5" id="exp-dots">
        <button class="exp-dot h-2.5 rounded-full bg-white transition-all duration-300" style="width:2rem" data-idx="0" aria-label="Slide 1"></button>
        <button class="exp-dot h-2.5 w-2.5 rounded-full bg-white/40 transition-all duration-300" data-idx="1" aria-label="Slide 2"></button>
        <button class="exp-dot h-2.5 w-2.5 rounded-full bg-white/40 transition-all duration-300" data-idx="2" aria-label="Slide 3"></button>
        <button class="exp-dot h-2.5 w-2.5 rounded-full bg-white/40 transition-all duration-300" data-idx="3" aria-label="Slide 4"></button>
      </div>
    </div>
  </section>

  <script is:inline>
  (function () {
    var track  = document.getElementById('exp-track');
    var dots   = document.querySelectorAll('.exp-dot');
    var cur    = 0;
    var total  = 4;
    var timer;

    function goTo(n) {
      cur = (n + total) % total;
      track.style.transform = 'translateX(-' + cur * 100 + '%)';
      dots.forEach(function (d, i) {
        d.style.width   = i === cur ? '2rem'     : '0.625rem';
        d.style.opacity = i === cur ? '1'        : '0.4';
      });
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(function () { goTo(cur + 1); }, 5000);
    }

    document.getElementById('exp-prev').addEventListener('click', function () { goTo(cur - 1); startAuto(); });
    document.getElementById('exp-next').addEventListener('click', function () { goTo(cur + 1); startAuto(); });
    dots.forEach(function (d) {
      d.addEventListener('click', function () { goTo(parseInt(d.dataset.idx, 10)); startAuto(); });
    });

    // Touch/swipe support
    var startX = 0;
    var wrap = document.getElementById('exp-wrap');
    wrap.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; }, { passive: true });
    wrap.addEventListener('touchend', function (e) {
      var diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) { goTo(diff > 0 ? cur + 1 : cur - 1); startAuto(); }
    });

    goTo(0);
    startAuto();
  })();
  </script>

  <!-- Wat we voor je doen -->
  <section class="bg-slate-50 py-24">
    <div class="container">
      <div class="mb-14 max-w-2xl">
        <span class="section-label">Wat we doen</span>
        <h2 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 lg:text-5xl">Alles voor jouw online groei</h2>
        <p class="mt-4 text-lg text-slate-500 leading-relaxed">Duidelijke websites, lokale SEO en maandelijkse content waarmee je structureel beter scoort in jouw regio.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">

